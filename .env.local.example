# Clerk (https://dashboard.clerk.com or Vercel Marketplace integration)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app

# Upstash Redis (https://console.upstash.com or Vercel Marketplace integration)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# Optional: override the Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL_ID=gemini-2.5-flash
# Generate with: openssl rand -hex 32
SERVER_ENCRYPTION_KEY=

# PostHog (https://posthog.com — use eu.i.posthog.com for EU cloud)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Optional: PostHog popover survey ID (from Surveys → your survey → URL/settings)
# When set, the native PostHog survey is used instead of the in-app feedback drawer.
NEXT_PUBLIC_POSTHOG_FEEDBACK_SURVEY_ID=
